PORT=8080
RUST_LOG=info
LOCAL_DEV=true
GCLOUD_REGION=europe-west1
SERVICE_NAME=converge-runtime

# Default hosted path: Google Cloud + Firebase
GCP_PROJECT_ID=your-gcp-project
GOOGLE_CLOUD_PROJECT=your-gcp-project
FIREBASE_PROJECT_ID=your-gcp-project
FIREBASE_AUTH_EMULATOR_HOST=
CONVERGE_RUNTIME_FEATURES=gcp,auth,firebase
TF_STATE_BUCKET=your-terraform-state-bucket

# Optional local emulator wiring
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8081

# Optional provider keys live in crates/provider/.env.example
# Production secrets should go to Google Secret Manager, not this file.
